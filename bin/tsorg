#!/usr/bin/env bash
# tsorg — organize wrapper for macOS / Linux (and WSL).
# Runs native python3 with config.local.json when present, else config.json.
set -euo pipefail
here="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
repo="$(dirname "$here")"
config="$repo/config.json"
[ -f "$repo/config.local.json" ] && config="$repo/config.local.json"
export PYTHONUTF8=1
exec python3 "$repo/cli.py" organize --config "$config" --verbose "$@"
